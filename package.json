{
  "name": "@featureflip/node",
  "version": "1.0.0",
  "description": "Node.js server SDK for Featureflip",
  "license": "Apache-2.0",
  "homepage": "https://featureflip.io/docs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@featureflip/js": "file:../js-sdk"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
